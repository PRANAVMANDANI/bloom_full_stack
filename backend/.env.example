# MongoDB Atlas connection string
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<cluster>
DATABASE_NAME=bloom

# JWT Configuration
# Generate a strong secret with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=generate-a-random-64-char-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Groq API (get a key at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google OAuth (create credentials at https://console.cloud.google.com/apis/credentials)
# Use the "Web application" OAuth 2.0 Client ID. Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Email via Brevo's HTTP API (get a free API key at https://app.brevo.com ->
# Settings -> SMTP & API -> API Keys). Uses HTTPS, not SMTP, so it works
# reliably on hosts that block outbound SMTP ports (e.g. Render's free tier).
# Leave BREVO_API_KEY blank to log the verification link to the console
# instead of sending (dev mode).
BREVO_API_KEY=xkeysib-your-brevo-api-key-here
FROM_EMAIL=you@example.com
FROM_NAME=BLOOM
EMAIL_VERIFICATION_EXPIRE_HOURS=24

# Frontend URL (for CORS + verification links). Set this to your deployed
# Vercel URL in production (e.g. https://bloom-app.vercel.app).
FRONTEND_URL=http://localhost:5173

# Optional: extra allowed CORS origins beyond FRONTEND_URL, comma-separated
# (e.g. a custom domain). Local dev ports and *.vercel.app preview URLs are
# always allowed automatically, so you don't need to list those here.
CORS_ALLOWED_ORIGINS=
