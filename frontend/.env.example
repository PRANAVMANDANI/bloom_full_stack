# Backend API base URL
VITE_API_URL=http://localhost:8000

# Google OAuth Web client ID (same value as backend GOOGLE_CLIENT_ID).
# Create it at https://console.cloud.google.com/apis/credentials and add
# http://localhost:5173 as an authorized JavaScript origin.
# Leave blank to hide the "Continue with Google" button.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
